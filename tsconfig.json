{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@features/*": ["./src/features/*"],
      "@config/*": ["./src/config/*"],
      "@types/*": ["./src/types/*"],
      "@context/*": ["./src/context/*"],
      "@utils/*": ["./src/utils/*"],
      "@services/*": ["./src/services/*"]
    },
    "jsx": "react-jsx",
    "allowJs": true
  },
  "include": [
    "src",
    "test",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "eslint.config.js",
    "scripts/**/*.cjs"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "playwright-report",
    "test-results",
    "android",
    "coverage"
  ]
}
